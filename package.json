{
  "name": "messenger-premium",
  "version": "1.3.0",
  "description": "Ứng dụng Messenger Desktop cho Windows - Chạy trên nhân Chrome (Chromium)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.messenger.premium",
    "productName": "Messlỏ",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.icns",
      "category": "public.app-category.social-networking",
      "artifactName": "Messlo-${version}-mac.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "custom_style.css",
      "icon.ico",
      "icon.icns",
      "icon.png",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "nct88",
        "repo": "Messenger-Win"
      }
    ]
  },
  "keywords": [
    "messenger",
    "facebook",
    "desktop",
    "electron"
  ],
  "author": "TruongIT",
  "license": "MIT",
  "devDependencies": {
    "electron": "29.4.6",
    "electron-builder": "24.13.3"
  },
  "dependencies": {
    "electron-updater": "6.8.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0"
  }
}
